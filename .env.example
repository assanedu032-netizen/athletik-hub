# ════════════════════════════════════════════════════════════════════════════
# ATHLETIK HUB — Variables d'environnement
# ────────────────────────────────────────────────────────────────────────────
# Ce fichier documente les CLÉS attendues. Les vraies valeurs ne sont JAMAIS
# stockées ici ni dans le repo — elles vivent dans Netlify Site Settings →
# Environment variables (https://app.netlify.com/sites/athletikhub/settings/env).
#
# Pour le dev local :
#   cp .env.example .env.local
#   # puis remplir .env.local avec les vraies valeurs (.env.local est .gitignored)
# ════════════════════════════════════════════════════════════════════════════

# ─── Anthropic (Titan AI proxy) ───────────────────────────────────────────
# Clé sk-ant-api03-... générée sur console.anthropic.com → API Keys.
# Utilisée par netlify/functions/titan.js pour proxifier les appels Claude.
# Cap par défaut : 20 messages/jour/uid (modifiable dans titan.js).
ANTHROPIC_API_KEY=

# ─── Codes d'accès post-livre (HMAC secret) ──────────────────────────────
# Secret HMAC-SHA256 utilisé pour générer ET valider les codes
# LETTRE-RANDOM6-CHECK4 (BETA/VIP/MASTER).
# Génération recommandée : openssl rand -hex 32
# /!\ Si tu changes cette valeur, TOUS les anciens codes deviennent invalides.
ACCESS_CODE_SECRET=

# ─── Firebase Cloud Messaging (Push notifs) ──────────────────────────────
# Clé VAPID publique exposée au client par netlify/functions/notif-config.js.
# Récupérable dans Firebase Console → Project Settings → Cloud Messaging →
# Web Push certificates → Generate key pair → copier "Key pair".
FIREBASE_VAPID_KEY=

# Service Account JSON COMPLET (string single-line, sans line breaks).
# Récupérable dans Firebase Console → Project Settings → Service accounts →
# Generate new private key → JSON.
# Utilisé par netlify/functions/send-notif.js pour signer les JWT et appeler
# l'API FCM v1.
# Astuce : coller le JSON brut, Netlify gère bien les guillemets dans la value.
FIREBASE_SERVICE_ACCOUNT=

# ─── OpenAI (embeddings RAG + moderation) ────────────────────────────────
# Clé sk-... générée sur platform.openai.com → API Keys.
# Utilisée par :
#   - netlify/functions/admin-build-index.js → embeddings text-embedding-3-large
#     pour construire l'index RAG du livre (data/livre.md)
#   - netlify/functions/titan.js → moderation omni-moderation-latest avant
#     d'envoyer le message à Anthropic
# Coût : ~0.50 € pour reconstruire l'index complet du livre (one-shot).
OPENAI_API_KEY=

# ─── Admin token (reconstruction RAG) ────────────────────────────────────
# Secret choisi par toi (ex. ah-rebuild-Xy7k2026). Protège l'endpoint
# /.netlify/functions/admin-build-index pour éviter qu'un random reconstruise
# l'index (et brûle ton crédit OpenAI).
# Doit MATCHER exactement la variable du même nom dans Netlify.
# Utilisé en local par : npm run rebuild-rag (cf scripts/rebuild-rag.js)
ADMIN_BUILD_TOKEN=

# URL du site (optionnel, défaut https://athletikhub.netlify.app)
# Utile pour pointer sur un deploy preview Netlify si tu testes une branche.
SITE_URL=

# ─── Netlify build settings ──────────────────────────────────────────────
# Force le scanner Netlify à NE PAS bloquer le build à cause de la Firebase
# Web API key (AIzaSy...) qui apparaît en clair dans index.html.
# Cette clé est PUBLIQUE par design (la sécurité Firebase repose sur
# Firestore Rules + Auth + Authorized domains, pas sur le secret de la clé).
# Sans ce flag, le build Netlify échoue avec "Secret found in code".
SECRETS_SCAN_SMART_DETECTION_ENABLED=false

# ─── Optionnel — Lakera (prompt injection guard, non utilisé) ────────────
# Garde gratuit anti-prompt-injection. Non branché en MVP, prévu Phase 3.
# LAKERA_API_KEY=

