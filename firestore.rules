// Athletik Hub — Firestore Security Rules
// À appliquer dans Firebase Console → Firestore → Rules
//
// Modèle : chaque utilisateur ne peut lire/écrire QUE son propre document
// /users/{uid}. Les codes d'accès post-livre, les badges et les paramètres
// utilisateur vivent tous dans ce document unique.

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─────────────────────────────────────────────────────
    // /users/{uid} — profil athlète (owner-only)
    // ─────────────────────────────────────────────────────
    match /users/{uid} {
      allow read:   if request.auth != null && request.auth.uid == uid;
      allow create: if request.auth != null && request.auth.uid == uid
                    && validProfileShape(request.resource.data);
      allow update: if request.auth != null && request.auth.uid == uid
                    && validProfileUpdate(request.resource.data, resource.data);
      allow delete: if false; // Pas de suppression — on conserve l'historique
    }

    // Sous-collections potentielles : history, badges, sessions
    match /users/{uid}/{subcollection}/{docId} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // ─────────────────────────────────────────────────────
    // Tout le reste : refusé par défaut
    // ─────────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }

  // ─────────────────────────────────────────────────────
  // Validation helpers
  // ─────────────────────────────────────────────────────
  function validProfileShape(data) {
    return data.keys().hasAny(['profile', 'updatedAt'])
        && data.size() < 50; // évite les payloads abusifs
  }

  function validProfileUpdate(newData, oldData) {
    // Empêche un utilisateur de monter son propre accessTier vers MASTER côté client
    // (le tier doit être set par une Cloud Function après vérification).
    // Tant que les tiers sont gérés côté client (BETA/VIP/MASTER via codes du livre),
    // cette règle est relâchée — durcir si on passe à une vérification Stripe/Amazon.
    return validProfileShape(newData);
  }
}
