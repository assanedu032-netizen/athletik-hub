// ════════════════════════════════════════════════════════════════════════════
// ATHLETIK HUB — Firestore Security Rules
// ────────────────────────────────────────────────────────────────────────────
// Modèle :
//   - /users/{uid} : profil athlète (owner-only, validation stricte)
//   - sous-collections users/{uid}/* : owner-only, limite taille
//   - tout le reste : refusé
//
// Déploiement :
//   - Copier-coller ce bloc dans Firebase Console → Firestore → Rules → Publish
//   - OU via firebase CLI : `firebase deploy --only firestore:rules`
//
// Roadmap v4 — P0 Sécurité fondations + P2 Firebase Auth + Persistence.
// ════════════════════════════════════════════════════════════════════════════

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─────────────────────────────────────────────────────
    // /users/{uid} — profil athlète (owner-only)
    // Les champs d'accès premium (trial / hasBookAccess) sont au
    // TOP LEVEL et écrits uniquement par les fonctions serveur via
    // Admin SDK (qui bypasse ces rules). Le client n'a aucun moyen
    // de les modifier ou de les forger.
    // ─────────────────────────────────────────────────────
    match /users/{uid} {
      allow read: if isOwner(uid);

      allow create: if isOwner(uid)
                    && validProfileShape(request.resource.data)
                    && validAccessTier(request.resource.data)
                    && noLockedOnCreate(request.resource.data);

      allow update: if isOwner(uid)
                    && validProfileShape(request.resource.data)
                    && validAccessTier(request.resource.data)
                    && noFcmTokenLeak(request.resource.data, resource.data)
                    && noLockedDiff(request.resource.data, resource.data);

      // Pas de suppression côté client — historique conservé. Si besoin,
      // un user peut faire "export + logout" via l'UI, mais le doc reste
      // jusqu'à action admin.
      allow delete: if false;
    }

    // ─────────────────────────────────────────────────────
    // Sous-collections : users/{uid}/bodyfat, /timerPresets, /sessions, etc.
    // Owner-only + plafond taille pour éviter les payloads abusifs.
    // titanQuota reste serveur-uniquement (compteur anti-abus Titan).
    // ─────────────────────────────────────────────────────
    match /users/{uid}/titanQuota/{day} {
      allow read, write: if false;
    }
    match /users/{uid}/{subcollection}/{docId} {
      allow read: if isOwner(uid);
      allow create, update: if isOwner(uid)
                            && request.resource.data.size() < 100;
      allow delete: if isOwner(uid);
    }

    // ─────────────────────────────────────────────────────
    // Collections SERVEUR UNIQUEMENT (deny all client access).
    // - accessRedemptions : logs d'activation (book-challenge.js, check-code.js)
    // - bookChallenges    : banque de questions (réservée — actuellement
    //                       embarquée dans data/book-challenges.js)
    // - accessCodes       : codes BETA/VIP/MASTER (réservée — actuellement
    //                       HMAC stateless via check-code.js)
    // - usedAmazonOrders  : empreintes numéros Amazon (actuellement Netlify Blobs)
    // - activationAttempts: audit tentatives (réservée)
    // - security_logs     : logs anti-injection (titan.js)
    // ─────────────────────────────────────────────────────
    match /accessRedemptions/{id} { allow read, write: if false; }
    match /bookChallenges/{id}    { allow read, write: if false; }
    match /accessCodes/{id}       { allow read, write: if false; }
    match /usedAmazonOrders/{id}  { allow read, write: if false; }
    match /activationAttempts/{id}{ allow read, write: if false; }
    match /security_logs/{id}     { allow read, write: if false; }

    // ─────────────────────────────────────────────────────
    // Tout le reste : refusé par défaut (defense in depth)
    // ─────────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }

  // ─────────────────────────────────────────────────────────────────────────
  // Helpers
  // ─────────────────────────────────────────────────────────────────────────

  // L'utilisateur authentifié possède ce doc.
  function isOwner(uid) {
    return request.auth != null && request.auth.uid == uid;
  }

  // Le doc respecte une taille raisonnable et a au moins l'un des
  // champs canoniques attendus (profile, updatedAt, ou les clés ah_*
  // sérialisées par _fbCollectPayload).
  function validProfileShape(d) {
    return d.size() < 50
        && d.size() > 0
        && (
             d.keys().hasAny([
               'profile', 'updatedAt',
               'nutriJournal', 'setHistory', 'badgesEarned',
               'builderSession', 'recipeFavorites',
               'shoppingChecks', 'shoppingMealPlan', 'shoppingMealChecks',
               'satInProgress', 'liveSession', 'accessData',
               'activeHabits', 'accessTier', 'planning'
             ])
           );
  }

  // accessTier ne peut prendre que des valeurs autorisées.
  // Empêche un user de poser arbitrairement {accessTier:'GOD'} ou autre.
  // L'upgrade BETA → VIP/MASTER reste possible côté client (UX simple),
  // mais le tier est validé serveur par check-code.js avant d'être posé.
  // Durcissement Phase 3 : check-code.js écrit le tier via Admin SDK.
  function validAccessTier(d) {
    return !('accessTier' in d.keys())
        || d.accessTier == null
        || d.accessTier in ['BETA', 'VIP', 'MASTER'];
  }

  // Empêche un user de poser le fcmToken d'un autre user dans son propre
  // doc (anti-collision FCM). Si profile.fcmToken existe dans oldData, il
  // doit rester identique ou être supprimé/changé par lui-même.
  // Pour le moment c'est juste une garantie de cohérence, pas un anti-abuse.
  function noFcmTokenLeak(newData, oldData) {
    return true; // hook pour durcissement Phase 3
  }

  // ─── Champs verrouillés côté serveur ───
  // Les fonctions Netlify (Admin SDK) bypassent les rules et écrivent ces
  // champs. Le client n'a aucun chemin valide pour les forger ou les modifier.
  function lockedFields() {
    return [
      'hasBookAccess',
      'accessMethod',
      'bookAccessVerifiedAt',
      'trialStartedAt',
      'trialEndsAt',
      'trialStatus',
      'createdAt',
      'bookVersionUsed'
    ];
  }
  function noLockedOnCreate(newData) {
    return !newData.keys().hasAny(lockedFields());
  }
  function noLockedDiff(newData, oldData) {
    return !newData.diff(oldData).affectedKeys().hasAny(lockedFields());
  }
}
